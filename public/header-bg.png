				<div class="elementor-element elementor-element-0a6d1ff elementor-widget elementor-widget-html" data-id="0a6d1ff" data-element_type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<script>
document.addEventListener("DOMContentLoaded", function() {
  // Wait for Elementor to fully initialize
  setTimeout(function() {
    // Function to get current page path
    function getCurrentPath() {
      return window.location.pathname.toLowerCase();
    }
    
    // Get all menu items that match our layout from the screenshot
    const menuItems = document.querySelectorAll('a[href*="about-us"], a:contains("About Us"), a[href*="examination"], a:contains("Examination")');
    
    // Determine which section we're in based on URL
    const currentPath = getCurrentPath();
    const inAboutSection = currentPath.includes('about');
    const inExamSection = currentPath.includes('exam');
    
    // Function to properly open a dropdown in Elementor
    function openElementorDropdown(menuItem) {
      // Get the containing li
      const menuItemLi = menuItem.closest('li');
      if (!menuItemLi) return;
      
      // Some Elementor menus use click to toggle, so we need to force the state
      menuItemLi.classList.add('current-menu-ancestor', 'current-menu-parent');
      menuItem.classList.add('elementor-item-active');
      
      // Find the dropdown/submenu
      const submenu = menuItemLi.querySelector('ul.sub-menu');
      if (submenu) {
        // Force submenu to be visible with inline styles (high specificity)
        submenu.style.cssText = 'display: block !important; opacity: 1 !important; height: auto !important; visibility: visible !important; transform: none !important; pointer-events: auto !important;';
        
        // Elementor sometimes uses aria-expanded state
        menuItem.setAttribute('aria-expanded', 'true');
        
        // If there's a toggle arrow/button
        const toggles = menuItemLi.querySelectorAll('.sub-arrow, .elementor-toggle-icon');
        toggles.forEach(toggle => {
          toggle.classList.add('elementor-active');
          toggle.setAttribute('aria-expanded', 'true');
        });
      }
    }
    
    // Apply to matching section
    menuItems.forEach(item => {
      const text = item.textContent.trim().toLowerCase();
      const href = (item.getAttribute('href') || '').toLowerCase();
      
      if ((text.includes('about') || href.includes('about')) && inAboutSection) {
        openElementorDropdown(item);
      }
      else if ((text.includes('exam') || href.includes('exam')) && inExamSection) {
        openElementorDropdown(item);
      }
    });
    
    // Use MutationObserver to maintain our changes if Elementor tries to override them
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.type === 'attributes' || mutation.type === 'childList') {
          // Re-apply our changes if needed
          if (inAboutSection || inExamSection) {
            menuItems.forEach(item => {
              const text = item.textContent.trim().toLowerCase();
              const href = (item.getAttribute('href') || '').toLowerCase();
              
              if ((text.includes('about') || href.includes('about')) && inAboutSection) {
                openElementorDropdown(item);
              }
              else if ((text.includes('exam') || href.includes('exam')) && inExamSection) {
                openElementorDropdown(item);
              }
            });
          }
        }
      });
    });
    
    // Observe changes to the menu
    const menuContainer = document.querySelector('.elementor-nav-menu, .hfe-nav-menu, nav');
    if (menuContainer) {
      observer.observe(menuContainer, { 
        attributes: true, 
        childList: true, 
        subtree: true 
      });
    }
  }, 800); // Increase delay to ensure Elementor is fully loaded
});
</script>

<style>
/* More specific selectors to override Elementor's styles */
body .elementor-nav-menu li.current-menu-ancestor > ul.sub-menu,
body .hfe-nav-menu li.current-menu-ancestor > ul.sub-menu,
body nav li.current-menu-ancestor > ul.sub-menu {
  display: block !important;
  opacity: 1 !important;
  visibility: visible !important;
  height: auto !important;
  transform: none !important;
  transition: none !important;
  pointer-events: auto !important;
  position: static !important;
}

/* Style the active items */
body .elementor-nav-menu li.current-menu-ancestor > a,
body .hfe-nav-menu li.current-menu-ancestor > a,
body nav li.current-menu-ancestor > a {
  font-weight: bold !important;
  background-color: rgba(255, 255, 255, 0.1) !important;
}

/* Override any transitions that might be causing the visual glitch */
body .elementor-nav-menu li > ul.sub-menu,
body .hfe-nav-menu li > ul.sub-menu,
body nav li > ul.sub-menu {
  transition: none !important;
}
</style>				</div>
				</div>
